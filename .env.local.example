OPENAI_API_KEY=sk-...
NOTION_API_KEY=secret_...
NOTION_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google OAuth（Google Cloud Console で取得）
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxxxxxxxxxxxxxx

# NextAuth シークレット（openssl rand -base64 32 で生成）
AUTH_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# アクセスを許可するGoogleアカウントのメールアドレス
ALLOWED_EMAIL=your@gmail.com

# Vercel本番環境のURL（デプロイ後に設定）
AUTH_URL=https://your-app.vercel.app
